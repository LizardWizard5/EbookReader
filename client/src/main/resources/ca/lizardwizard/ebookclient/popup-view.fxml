<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="10.0"
      maxHeight="-Infinity" maxWidth="-Infinity"
      minHeight="-Infinity" minWidth="-Infinity"
      prefHeight="400.0" prefWidth="600.0"
      styleClass="root-container, popup-container"
      stylesheets="@style.css"
      xmlns="http://javafx.com/javafx/24.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ca.lizardwizard.ebookclient.PopupController">
   <children>

      <Text fx:id="titleText" strokeType="OUTSIDE" strokeWidth="0.0"
            styleClass="popup-title"
            text="TitleText" textAlignment="CENTER">
         <font>
            <Font size="35.0" />
         </font>
         <VBox.margin><Insets bottom="4.0" /></VBox.margin>
      </Text>

      <Text fx:id="messageText" strokeType="OUTSIDE" strokeWidth="0.0"
            styleClass="popup-message"
            text="ContentText" textAlignment="CENTER"
            wrappingWidth="480.0" />

      <TextArea fx:id="advancedText" disable="true" editable="false"
                styleClass="field-textarea, popup-advanced"
                prefHeight="180.0" prefWidth="480.0"
                wrapText="true">
         <VBox.margin><Insets left="40.0" right="40.0" top="6.0" /></VBox.margin>
      </TextArea>

      <Button mnemonicParsing="false" onAction="#dismissButton"
              styleClass="btn-primary" text="Dismiss">
         <VBox.margin><Insets top="8.0" /></VBox.margin>
      </Button>

   </children>
   <padding>
      <Insets top="36.0" bottom="36.0" left="20.0" right="20.0" />
   </padding>
</VBox>
