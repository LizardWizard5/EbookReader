<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="600.0"
            styleClass="root-container"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ca.lizardwizard.ebookclient.UploadPdfController">
   <children>

      <!-- ── Top Bar with Return button ── -->
      <HBox prefHeight="43.0" prefWidth="600.0" styleClass="upload-topbar" alignment="CENTER_LEFT">
         <children>
            <Button mnemonicParsing="false" onAction="#returnButton"
                    styleClass="btn-ghost-back" text="← Return" />
         </children>
         <padding>
            <Insets left="10.0" top="6.0" bottom="6.0" />
         </padding>
      </HBox>

      <!-- ── Main Form ── -->
      <VBox alignment="TOP_CENTER" layoutX="0.0" layoutY="43.0"
            prefHeight="357.0" prefWidth="600.0" styleClass="upload-form-container">
         <children>

            <!-- Form card -->
            <VBox styleClass="upload-card" spacing="4.0">
               <children>

                  <Text strokeType="OUTSIDE" strokeWidth="0.0"
                        styleClass="field-label" text="Book Title" />
                  <TextField fx:id="titleBox" styleClass="field-input"
                             promptText="e.g. The Great Gatsby" />

                  <Text strokeType="OUTSIDE" strokeWidth="0.0"
                        styleClass="field-label" text="Author">
                     <VBox.margin><Insets top="10.0" /></VBox.margin>
                  </Text>
                  <TextField fx:id="authorBox" styleClass="field-input"
                             promptText="e.g. F. Scott Fitzgerald" />

                  <Text strokeType="OUTSIDE" strokeWidth="0.0"
                        styleClass="field-label" text="Details">
                     <VBox.margin><Insets top="10.0" /></VBox.margin>
                  </Text>
                  <TextArea fx:id="detailBox" styleClass="field-textarea"
                            prefHeight="90.0" prefWidth="200.0"
                            promptText="A short description of the book…"
                            wrapText="true" />

                  <!-- Upload + Submit row -->
                  <HBox prefHeight="50.0" prefWidth="400.0" alignment="CENTER"
                        spacing="10.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#uploadButton"
                                styleClass="btn-secondary"
                                prefHeight="30.0" prefWidth="120.0"
                                text="📄  Upload PDF" />
                        <Button mnemonicParsing="false" onAction="#uploadCoverButton"
                                styleClass="btn-secondary"
                                prefHeight="30.0" prefWidth="120.0"
                                text="🖼  Upload Cover" />
                        <Button mnemonicParsing="false" onAction="#submitButton"
                                styleClass="btn-primary"
                                prefHeight="30.0" prefWidth="100.0"
                                text="Submit" />
                     </children>
                     <VBox.margin><Insets top="14.0" /></VBox.margin>
                  </HBox>

               </children>
               <padding>
                  <Insets top="20.0" bottom="20.0" left="24.0" right="24.0" />
               </padding>
            </VBox>

            <!-- Notice -->
            <VBox alignment="CENTER" prefWidth="600.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0"
                        styleClass="upload-notice"
                        text="⏱  After uploading, please allow time for audio generation. This may take multiple hours depending on PDF length."
                        textAlignment="CENTER"
                        wrappingWidth="400.0" />
               </children>
               <VBox.margin><Insets top="14.0" /></VBox.margin>
            </VBox>

         </children>
         <padding>
            <Insets top="16.0" left="80.0" right="80.0" bottom="16.0" />
         </padding>
      </VBox>

   </children>
</AnchorPane>
